# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/cashgame"
# Optional: separate shadow database for `prisma migrate dev` (development only)
SHADOW_DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/cashgame_shadow"
# Random secret used to sign/derive auth session tokens (>= 32 chars).
# Generate with: openssl rand -hex 32
SESSION_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
NODE_ENV="production"
